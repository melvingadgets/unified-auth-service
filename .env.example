# Auth Service Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=5500

# Database (use a SEPARATE MongoDB instance for the auth service)
DATABASE_URL=mongodb+srv://your_connection_string_here

# JWT (this secret MUST be shared with consumer backends)
AUTH_JWT_SECRET=replace_with_long_random_secret

# Service-to-service authentication key (backends use this to call internal endpoints)
AUTH_SERVICE_KEY=replace_with_long_random_service_key

# Public URL of this auth service (used for email verification/reset links)
AUTH_SERVICE_PUBLIC_URL=http://localhost:5500

# CORS (comma-separated list of allowed origins, or * for all)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Email / SMTP / Resend Configuration
MAIL_PROVIDER=resend
RESEND_API_KEY=re_your_api_key_here
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword
MAIL_FROM="Unified Auth <noreply@yourdomain.com>"
